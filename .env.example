# medscribe-ai — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.
#
# ⚠️ MVP posture: synthetic / demo data only. Do NOT put real PHI here
# or connect these keys to a project that holds real patient data.

# ── Supabase (free tier — NOT HIPAA-eligible without BAA + paid plan) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (Claude Sonnet 4.6 for SOAP note generation) ──
# Get a key at https://console.anthropic.com/settings/keys
# NOT HIPAA-eligible on standard API — requires BAA (Enterprise or AWS Bedrock) for real PHI.
ANTHROPIC_API_KEY=sk-ant-...

# ── Groq (hosted Whisper for audio transcription) ──
# Get a key at https://console.groq.com/keys  (free tier, no credit card)
# NOT HIPAA-eligible — requires BAA for real PHI.
GROQ_API_KEY=gsk_...

# ── App ──
# Keep true for the MVP. Displays the "demo — synthetic data only" banner.
NEXT_PUBLIC_DEMO_MODE=true
