# medscribe-ai — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.
#
# ⚠️ MVP posture: synthetic / demo data only. Do NOT put real PHI here
# or connect these keys to a project that holds real patient data.

# ── Supabase (free tier — NOT HIPAA-eligible without BAA + paid plan) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI (standard API — NOT HIPAA-eligible without enterprise BAA) ──
# Used by /api/transcribe (Whisper) and /api/generate-note (GPT-4o).
OPENAI_API_KEY=sk-your-key

# ── App ──
# Keep true for the MVP. Displays the "demo — synthetic data only" banner.
NEXT_PUBLIC_DEMO_MODE=true
